## Activitat 1.3

- Crea i copia en el fitxer **`menu.py`** tot contingut:

```python
# print("\n------ CALCULADORA ------")
# print("1. Suma")
# print("2. Resta")
# print("3. Producte")
# print("4. Divisió")
# print("5. Parell/Senar")
# print("6. Positiu/Negatiu")
# print("0. Sortir")
# print("-"*25)
# print("Escull una opció: ", end="")

# Definició constants
CARACTER = "-"
AMPLE=50

def pintaTitolEsquerra(titol,mida=AMPLE):
    midaTitol = len(titol)
    qtatEspais = mida - midaTitol
    print(f"{titol}{" "*qtatEspais}")

def pintaTitolDreta(titol,mida=AMPLE):
    midaTitol = len(titol)
    qtatEspais = mida - midaTitol
    print(f"{" "*qtatEspais}{titol}")

def pintaTitolCentrat(titol,mida=AMPLE):
    midaTitol = len(titol)
    qtatEspais = mida - midaTitol
    qtatEspaisAbans = qtatEspais // 2
    qtatEspaisDespres = qtatEspais - qtatEspaisAbans
    print(f"{" "*qtatEspaisAbans}{titol}{" "*qtatEspaisDespres}")

def pintaLinia(caracter=CARACTER, mida=AMPLE):
    print(caracter*mida)

def pintaMenu(llistatOpcions, titol):
    pintaLinia("=")
    pintaTitolCentrat(titol)
    pintaLinia("=")
    qtatOpcions = len(llistatOpcions) # lenght

    for i in range(1,qtatOpcions):
        print(f"{i}. {llistatOpcions[i]}")
    print(f"0. {llistatOpcions[0]}")
    pintaLinia()
    print("Escull una opció: ", end="")
```

